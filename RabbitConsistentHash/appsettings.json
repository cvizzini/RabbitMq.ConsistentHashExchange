{
  "RabbitMQ": {
    "HostName": "localhost",
    "UserName": "guest",
    "Password": "guest",
    "Port": 5672,
    "VirtualHost": "/",
    "Exchange": {
      "Name": "account-hash-exchange",
      "Type": "x-consistent-hash",
      "HashHeader": "accountId"
    },
    "Queue": {
      "Prefix": "queue.account",
      "Count": 10,
      "Durable": true,
      "AutoDelete": false,
      "Exclusive": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Publisher": {
    "MessageIntervalSeconds": 1,
    "MessageCount": -1
  }
}